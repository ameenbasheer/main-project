# Copy this file to .env and fill in your own values
PORT=5000
NODE_ENV=development

# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/grownroot

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# Seed admin account (used by `npm run seed:admin`)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@grownroot.com
ADMIN_PASSWORD=Admin@123

# Groq (free, no credit card) — get a key at https://console.groq.com/keys
# Used by /api/ai/* for daily plans, crop suggestions, disease detection, and chat.
GROQ_API_KEY=
# Optional model overrides. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
